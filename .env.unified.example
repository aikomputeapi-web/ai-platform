# AI Platform — Environment Template
# Copy to .env or let setup.sh generate it automatically.

DOMAIN=aiapi.indevs.in
PUBLIC_URL=https://aiapi.indevs.in
SSL_ENABLED=true

# PostgreSQL
POSTGRES_USER=aiplatform
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=aiplatform

# Redis
REDIS_PASSWORD=CHANGE_ME

# OmniRoute
OMNIROUTE_JWT_SECRET=CHANGE_ME
OMNIROUTE_API_KEY_SECRET=CHANGE_ME
OMNIROUTE_INITIAL_PASSWORD=CHANGE_ME
OMNIROUTE_STORAGE_ENCRYPTION_KEY=CHANGE_ME
OMNIROUTE_DASHBOARD_PORT=20128
OMNIROUTE_API_PORT=20129
